/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  # style-src retains 'unsafe-inline' because several pages (CurvePlot, ShiftRowsAnimation,
  # progress bars) compute pixel positions at runtime via React style={{}} props. CSP2's
  # 'unsafe-hashes' would need build-time hashes for every literal style string — impossible
  # with runtime-computed values. A nonce-based pipeline is tracked as future work.
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self'; connect-src 'self'; img-src 'self' data:; font-src 'self' data:; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; report-uri /csp-report

/index.html
  Cache-Control: no-cache

/assets/*
  Cache-Control: public, max-age=31536000, immutable
